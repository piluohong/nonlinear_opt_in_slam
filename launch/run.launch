<launch>
    <node ns="hong_test" name="mid360Toimage" pkg="ls_slam" type="ls_slam" output="screen" clear_params="true">
    </node>

    <node ns ="hong_test" pkg="tf" type="static_transform_publisher" name="lidar_cam_broadcaster" args=" 0. 0. 0. 0. 0. 0. 1. livox_frame world 100"/>
    <node pkg="image_transport" type="republish" name="ls_slam_republish" args="compressed in:=/left_camera/image raw out:=/camera/image" output="screen" respawn="true"/>
</launch>
